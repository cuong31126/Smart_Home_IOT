# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# MQTT Broker
# Wokwi co the dung broker public nay de demo.
MQTT_BROKER_URL=mqtt://broker.hivemq.com:1883
MQTT_CLIENT_ID=smarthome-backend
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1
MQTT_CONTROL_RETAIN=false

# Firebase Realtime Database
FIREBASE_DATABASE_URL=https://iotdemo31126-default-rtdb.asia-southeast1.firebasedatabase.app

# Cach 1: dat file service account trong backend/serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Cach 2 neu khong muon luu file json: dung JSON string hoac base64.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
